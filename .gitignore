# =========================

# Rider + .NET Core .gitignore

# Production Ready Template

# =========================

# -------------------------

# Build results

# -------------------------

[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/

# -------------------------

# Rider / JetBrains

# -------------------------

.idea/
*.sln.iml

# Optional Rider user-specific files

.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# -------------------------

# Visual Studio (if mixed usage)

# -------------------------

.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# -------------------------

# OS files

# -------------------------

.DS_Store
Thumbs.db

# -------------------------

# Logs

# -------------------------

*.log
logs/

# -------------------------

# NuGet

# -------------------------

*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# -------------------------

# Node (if frontend present)

# -------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------

# Environment & Secrets

# -------------------------

appsettings.Development.json
appsettings.Local.json
appsettings.*.json
!appsettings.json

# User secrets

secrets.json

# -------------------------

# Database files

# -------------------------

*.mdf
*.ldf
*.ndf

# -------------------------

# Publish output

# -------------------------

publish/
*.publish.xml
*.azurePubxml

# -------------------------

# Test results

# -------------------------

TestResults/
*.trx

# -------------------------

# Coverage

# -------------------------

coverage/
coverage*.json
coverage*.xml

# -------------------------

# Resharper / DotCover

# -------------------------

_ReSharper*/
*.DotSettings.user
*.dotCover

# -------------------------

# Temporary files

# -------------------------

*.tmp
*.temp
*~

# -------------------------

# Web root generated files (optional)

# -------------------------

wwwroot/dist/
wwwroot/build/

# -------------------------

# Custom project ignores

# -------------------------

/Presentation/Web/App/wwwroot/attachments/
/Presentation/Web/App/wwwroot/Agent/Signature/

# -------------------------

# Misc

# -------------------------

*.cache
*.pidb
*.svclog

# =========================

# END

